  m_Script: {fileID: 11500000, guid: fefb186eed8b8fc479d5f4af405e9691, type: 3}
  m_Name: Didereg Before Quest
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  characterName: Mr. Didereg
  sentences:
  - "Kedves Fiam!\nOlyan hideg van a szob\xE1mban, hogy egy jegesmedve tudna ott
    csak el\xE9lni. Meg is f\xE1ztam! H\xC1\xC1\xC1\xC1\xC1\xC1\xC1PSZIIIII!\nAzonnal
    jav\xEDtsd meg nekem, mert nem \xE1llok j\xF3t magam\xE9rt!"
